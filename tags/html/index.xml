	width=&#34;429&#34;
	height=&#34;76&#34;
	srcset=&#34;https://Elysia492.github.io/p/elysia03/index.assets/image-20260318184658502_hu12013598271806253498.png 480w, https://Elysia492.github.io/p/elysia03/index.assets/image-20260318184658502_hu8303168703509376806.png 1024w&#34;
	loading=&#34;lazy&#34;
	
