&gt;&lt;/p&gt;
&lt;p&gt;&lt;img src=&#34;https://Elysia492.github.io/p/elysia03/index.assets/image-20260318192448941.png&#34;
	width=&#34;643&#34;
	height=&#34;176&#34;
	srcset=&#34;https://Elysia492.github.io/p/elysia03/index.assets/image-20260318192448941_hu2341462099780057123.png 480w, https://Elysia492.github.io/p/elysia03/index.assets/image-20260318192448941_hu9050361285443976225.png 1024w&#34;
	loading=&#34;lazy&#34;
	
		alt=&#34;image-20260318192448941&#34;
	
	
		class=&#34;gallery-image&#34; 
		data-flex-grow=&#34;365&#34;
		data-flex-basis=&#34;876px&#34;
	
